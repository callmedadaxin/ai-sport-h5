    "format:check": "prettier --check ."
  },
  "dependencies": {
    "axios": "^1.6.8",
    "cropperjs": "^1.6.2",
    "exif-js": "^2.3.0",
    "exifr": "^7.1.3",
    "html2canvas": "^1.4.1",
    "pinia": "^2.1.7",
    "qrcode": "^1.5.3",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "prettier": "^3.8.1",
    "vite": "^5.2.0"
  }
}
