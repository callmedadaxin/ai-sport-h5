{
  "name": "h5-wanmei",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.14.2",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "pnpm build && pnpm scp1 && pnpm scp2",
    "scp1": "scp -r dist/* h51:/var/www/h5/",
    "scp2": "scp -r dist/* h52:/var/www/h5/",
